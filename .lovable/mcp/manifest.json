{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "hippo-technology-mcp",
      "version": "0.1.0",
      "title": "Hippo Technology Store"
    },
    "tools": [
      {
        "name": "list_products",
        "title": "List products",
        "description": "List all smartphones available in the Hippo Technology store, including price (RWF), stock, rating, and category.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "Optional category filter (e.g. 'iphone', 'samsung').",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_product",
        "title": "Get product details",
        "description": "Get full details for one smartphone by product id, including tagline, colors, price, and stock.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "description": "Product id, e.g. 'iphone-16-pro-max'."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "search_products",
        "title": "Search products",
        "description": "Search smartphones by free-text query against name, tagline, and category. Optional price range in RWF.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "description": "Free-text search string.",
              "type": "string"
            },
            "min_price": {
              "description": "Minimum price in RWF.",
              "type": "number",
              "minimum": 0
            },
            "max_price": {
              "description": "Maximum price in RWF.",
              "type": "number",
              "minimum": 0
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
